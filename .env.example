SECRET_KEY=generate-with-openssl-rand-hex-32
POSTGRES_USER=spsm
POSTGRES_PASSWORD=spsm_dev_change_me
POSTGRES_DB=spsm
DATABASE_URL=postgresql+asyncpg://spsm:spsm_dev_change_me@localhost:5432/spsm
CORS_ORIGINS=http://localhost:5173
# Allow phones/tablets on your LAN (192.168.x.x:5173, hostname, or .local) when the UI talks to :8000 directly
# CORS_ALLOW_PRIVATE_NETWORKS=true
# URL for links in alert emails (use your LAN IP if you open the portal that way)
# PORTAL_PUBLIC_URL=http://192.168.1.50:5173
# Router IP — required for LAN PVS scan when the API runs in Docker (set to your gateway, any subnet).
LAN_DNS=192.168.0.1
# Only if auto-detection fails: this machine's LAN IP (any private subnet).
# SPSM_HOST_LAN_IP=192.168.5.42
